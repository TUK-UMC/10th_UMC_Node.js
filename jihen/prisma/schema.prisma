generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum StoreCategory {
  KOREAN
  JAPANESE
  CHINESE
  WESTERN
  CAFE
  FAST_FOOD
  OTHER
}

enum MissionStatus {
  IN_PROGRESS
  COMPLETE
}

enum PointType {
  EARN
  USE
}

model Member {
  memberId      BigInt       @id @default(autoincrement()) @map("member_id")
  email         String       @unique @db.VarChar(50)
  password      String       @default("") @db.VarChar(255)
  nickname      String?      @db.VarChar(20)
  name          String       @db.VarChar(30)
  gender        Gender?
  birth         DateTime?    @db.Date
  address       String?      @db.VarChar(255)
  detailAddress String?      @map("detail_address") @db.VarChar(255)
  phoneNum      String?      @map("phone_num") @db.VarChar(15)
  status        MemberStatus @default(ACTIVE)
  point         Int          @default(0)
  provider      String?      @db.VarChar(50)
  providerId    String?      @map("provider_id") @db.VarChar(100)
  createdAt     DateTime     @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.DateTime(6)
  deletedAt     DateTime?    @map("deleted_at") @db.DateTime(6)

  favorCategories UserFavorCategory[]
  memberMissions  MemberMission[]
  pointHistory    PointHistory[]
  reviews         Review[]

  @@map("member")
}

model FoodCategory {
  foodCategoryId Int    @id @default(autoincrement()) @map("food_category_id")
  name           String @db.VarChar(50)

  favorCategories UserFavorCategory[]

  @@map("food_category")
}

model UserFavorCategory {
  userFavorCategoryId Int    @id @default(autoincrement()) @map("user_favor_category_id")
  memberId            BigInt @map("member_id")
  foodCategoryId      Int    @map("food_category_id")

  member       Member       @relation(fields: [memberId], references: [memberId])
  foodCategory FoodCategory @relation(fields: [foodCategoryId], references: [foodCategoryId])

  @@index([foodCategoryId], map: "f_category_id")
  @@index([memberId], map: "member_id")
  @@map("user_favor_category")
}

model Region {
  regionId BigInt @id @default(autoincrement()) @map("region_id")
  name     String @db.VarChar(20)

  stores       Store[]
  pointHistory PointHistory[]

  @@map("region")
}

model Store {
  storeId   BigInt        @id @default(autoincrement()) @map("store_id")
  regionId  BigInt        @map("region_id")
  name      String        @db.VarChar(50)
  address   String        @db.VarChar(255)
  category  StoreCategory
  createdAt DateTime      @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt DateTime      @updatedAt @map("updated_at") @db.DateTime(6)

  region      Region       @relation(fields: [regionId], references: [regionId])
  storeImages StoreImage[]
  missions    Mission[]
  reviews     Review[]

  @@map("store")
}

model StoreImage {
  imageId   BigInt @id @default(autoincrement()) @map("image_id")
  storeId   BigInt @map("store_id")
  imageUrl  String @map("image_url") @db.VarChar(255)
  sortOrder Int    @default(0) @map("sort_order")

  store Store @relation(fields: [storeId], references: [storeId])

  @@map("store_image")
}

model Mission {
  missionId   BigInt    @id @default(autoincrement()) @map("mission_id")
  storeId     BigInt    @map("store_id")
  title       String    @db.VarChar(50)
  description String?   @db.Text
  rewardPoint Int       @default(0) @map("reward_point")
  startAt     DateTime? @map("start_at") @db.DateTime(6)
  endAt       DateTime? @map("end_at") @db.DateTime(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.DateTime(6)

  store          Store           @relation(fields: [storeId], references: [storeId])
  memberMissions MemberMission[]

  @@map("mission")
}

model MemberMission {
  memberMissionId BigInt        @id @default(autoincrement()) @map("member_mission_id")
  memberId        BigInt        @map("member_id")
  missionId       BigInt        @map("mission_id")
  status          MissionStatus @default(IN_PROGRESS)
  completedAt     DateTime?     @map("completed_at") @db.DateTime(6)
  createdAt       DateTime      @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.DateTime(6)

  member  Member  @relation(fields: [memberId], references: [memberId])
  mission Mission @relation(fields: [missionId], references: [missionId])

  @@map("member_mission")
}

model PointHistory {
  pointHistoryId BigInt    @id @default(autoincrement()) @map("point_history_id")
  memberId       BigInt    @map("member_id")
  regionId       BigInt    @map("region_id")
  point          Int
  type           PointType
  createdAt      DateTime  @default(now()) @map("created_at") @db.DateTime(6)

  member Member @relation(fields: [memberId], references: [memberId])
  region Region @relation(fields: [regionId], references: [regionId])

  @@map("point_history")
}

model Review {
  reviewId  BigInt   @id @default(autoincrement()) @map("review_id")
  memberId  BigInt   @map("member_id")
  storeId   BigInt   @map("store_id")
  body      String   @db.Text
  score     Float
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime(6)

  member Member @relation(fields: [memberId], references: [memberId])
  store  Store  @relation(fields: [storeId], references: [storeId])

  @@map("review")
}
